# Copy to .env.local and fill in the values:
#   cp .env.example .env.local

# --- Wallet (Reown / WalletConnect) ---
# Create a free project at https://cloud.reown.com and paste the Project ID.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# --- Convex (auto-filled by `npx convex dev`) ---
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# --- On-chain FHE contract ---
# Deploy from contracts/: npm run deploy:arb-sepolia
# Then paste the printed address here (must be 0x + 40 hex chars).
NEXT_PUBLIC_TRSTIT_CONTRACT_ADDRESS=

# 421614 = Arbitrum Sepolia (default), 11155111 = Ethereum Sepolia
NEXT_PUBLIC_CHAIN_ID=421614
